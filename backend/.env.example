APP_ENV=production
SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@db-host:5432/planifiweb_platform
CORS_ORIGINS=https://planifiweb-gateway-staging.vercel.app,https://planifiweb-app-staging.vercel.app
TRUSTED_HOSTS=planifiweb-api-staging.seenode.com
API_DOCS_ENABLED=false
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SQL_ECHO=false
REDIS_URL=redis://default:token@upstash-host:6379
ALLOWED_EMAIL_DOMAINS=

# Session cookie hardening
SESSION_COOKIE_NAME=planifiweb_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

# Legal document versions
LEGAL_TERMS_VERSION=2026-03
LEGAL_PRIVACY_VERSION=2026-03

# Receipt upload constraints
MAX_RECEIPT_FILE_MB=5
ALLOWED_RECEIPT_CONTENT_TYPES=image/jpeg,image/png,image/webp
LOCAL_UPLOAD_DIR=uploads/receipts
RECEIPT_URL_TTL_SECONDS=300
PAYMENT_PRECHECK_ENABLED=false
PAYMENT_VISION_PROVIDER=openrouter
PAYMENT_VISION_MODEL=
PAYMENT_VISION_API_KEY=
PAYMENT_VISION_BASE_URL=
PAYMENT_VISION_TIMEOUT_SECONDS=25
PAYMENT_YAPE_DESTINATION_NAME_MASKED=Guido Jar*
PAYMENT_YAPE_PHONE_LAST3=929
PAYMENT_AMOUNT_TOLERANCE=0.01

# S3 / S3-compatible storage (required in production)
S3_ENDPOINT_URL=https://accountid.r2.cloudflarestorage.com
S3_REGION=us-east-1
S3_BUCKET=planifiweb-receipts
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# AI routing
AI_PROVIDER=groq
AI_PROVIDER_CHAIN=groq,openrouter
AI_TIMEOUT_SECONDS=60
PUBLIC_APP_URL=https://planifiweb-gateway-staging.vercel.app

# Generic direct provider fallback (optional)
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=

# Groq primary candidate
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter fallback keys and router model
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
